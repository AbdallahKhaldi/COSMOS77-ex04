{
  "version": "1.00",
  "target": {
    "source": "bugsinpy",
    "project": "tqdm",
    "package_subdir": "tqdm",
    "bug_id": 1,
    "python_version": "3.8.20",
    "failing_test": "tqdm/tests/tests_contrib.py::test_enumerate",
    "workdir": "data/target",
    "isolation": "venv"
  },
  "graphify": {
    "out_dir": "graphify-out",
    "obsidian": true,
    "wiki": true
  },
  "agent": {
    "framework": "langgraph",
    "max_llm_calls": 6,
    "recursion_limit": 12,
    "max_output_tokens": 4096,
    "top_k": 6,
    "max_files": 4,
    "graph_guided_first": true
  },
  "tokens": {
    "baseline_mode": "raw_files",
    "guided_mode": "graph_guided",
    "measure": ["tokens", "files_read", "iterations", "time_to_root_cause"]
  },
  "paths": {
    "obsidian_dir": "obsidian",
    "reports_dir": "reports",
    "artifacts_dir": "artifacts"
  }
}
