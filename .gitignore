# Runtime logs (keep the directory, drop the rotating log files)
logs/*.log
logs/*.jsonl
!logs/.gitkeep

# BugsInPy target checkout — the isolated target repo + its own venv are NOT ours
# (CLAUDE.md rule 5). Keep the data/ directory; ignore the checked-out code.
data/target/
data/*
!data/.gitkeep

# Graphify HTML render can be large; KEEP graph.json + diagrams + reports + vault.
artifacts/graph.html
artifacts/*.html

# Cover-sheet artifacts (the cover PDF is generated OUTSIDE the repo in Phase 12)
*.filled.docx
uoh-rl07-ex01.docx
COSMOS77-ex04.pdf

# uv cache (the lock file IS committed)
.uv-cache/
